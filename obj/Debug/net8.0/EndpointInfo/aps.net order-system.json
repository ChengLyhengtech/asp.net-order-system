      "CategoriesDto": {
        "required": [
          "categoryName",
          "imageUrl"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "imageUrl": {
            "minLength": 1,
            "type": "string"
          },
          "categoryName": {
            "maxLength": 100,
            "minLength": 0,
            "type": "string"
          },
          "products": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ProductDto"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "CategoryCreateDto": {
        "required": [
